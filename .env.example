# AlphaInvestPro environment configuration
# Copy to .env and fill in your keys. Never commit real keys.

# QVeris.ai — financial data gateway (backend-only)
QVERIS_API_KEY=your_qveris_api_key_here
QVERIS_BASE_URL=https://qveris.ai/api/v1
QVERIS_SESSION_ID=alphainvestpro-local

# DeepSeek — the only LLM runtime (backend-only)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional overrides
# DATABASE_URL=sqlite:///./alphainvestpro.db
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
